{
  "name": "@getvision/server",
  "version": "0.4.4-61ad392-develop",
  "type": "module",
  "description": "Vision Server — Elysia-based meta-framework with built-in observability, pub/sub, and end-to-end type safety (Eden-ready)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc --emitDeclarationOnly && bun build ./src/*.ts --outdir ./dist --target bun --format esm --external '*' --sourcemap=external",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "license": "MIT",
  "dependencies": {
    "@getvision/core": "workspace:*",
    "bullmq": "^5.62.0",
    "ioredis": "^5.8.2",
    "zod": "^4.1.11"
  },
  "peerDependencies": {
    "elysia": "^1.4.28"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20.14.9",
    "@types/bun": "^1.3.5",
    "elysia": "^1.4.28",
    "typescript": "5.9.3"
  },
  "keywords": [
    "vision",
    "framework",
    "observability",
    "tracing",
    "elysia",
    "bun",
    "bullmq",
    "pub-sub",
    "type-safe",
    "eden",
    "event-driven"
  ],
  "config": {}
}
